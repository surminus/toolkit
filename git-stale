#!/usr/bin/env bash
set -euo pipefail

# The number of days to try removing old branches
OLDER_THAN_DAYS=365

function interactive_branch_delete() {
  local branches=$1
  local title=$2

  if [[ -z "${branches}" ]]; then
    echo "No ${title} branches discovered"
    return
  fi

  echo "${title^} branches to delete:"
  for branch in ${branches}; do
    echo "${branch}"
  done

  read -p "Delete these branches [y/n/[p]ick]? : " -n 1 -r response
  echo

  if [[ ${response} =~ ^[Pp]$ ]]; then
    for branch in ${branches}; do
      git show "${branch}"
      echo
      read -p "Delete ${branch}? [y/n] : " -n 1 -r answer
      echo

      if [[ ${answer} =~ ^[Yy]$ ]]; then
        git branch -D "${branch}"
      fi
    done

    return
  fi

  if [[ ! ${response} =~ ^[Yy]$ ]]; then
    return
  fi

  for branch in ${branches}; do
    git branch -D "${branch}"
  done
}

function worktree_branches() {
  git worktree list --porcelain | grep '^branch ' | sed 's|^branch refs/heads/||'
}

function stale() {
  local default_branch
  default_branch=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')

  local local_branches
  local_branches=$(git for-each-ref --format '%(refname)' refs/heads | sed 's|refs/heads/||g' | sort)

  local remote_branches
  remote_branches=$(git ls-remote --quiet --heads | awk '{print $2}' | sed 's|refs/heads/||g' | sort)

  local stale_branches
  local wt_branches
  wt_branches=$(worktree_branches)

  stale_branches=$(diff <(echo "${local_branches}") <(echo "${remote_branches}") | grep '^<' | awk '{print $2}' | grep -vxF "${default_branch}" | grep -vxF -f <(echo "${wt_branches}") || true)

  interactive_branch_delete "${stale_branches}" "stale"
}

function merged() {
  local default_branch
  default_branch=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')

  local wt_branches
  wt_branches=$(worktree_branches)

  local merged_branches
  merged_branches=$(git branch --merged | grep -v "${default_branch}\|\*\|+" | sed 's/^[[:space:]]*//' | sort | grep -vxF -f <(echo "${wt_branches}") || true)

  interactive_branch_delete "${merged_branches}" "merged"
}

function old() {
  local older_than_seconds=$((60 * 60 * 24 * OLDER_THAN_DAYS))
  local current
  current=$(date +%s)

  local wt_branches
  wt_branches=$(worktree_branches)

  local old_branches
  old_branches=$(git for-each-ref refs/heads | while read -r commit _type ref; do
    local headcd
    headcd=$(git log -1 --pretty=%cd --date=format:%s "${commit}")

    if [[ $((current-headcd)) -ge ${older_than_seconds} ]]; then
      echo "$ref" | sed 's|refs/heads/||g'
    fi
  done | sort | grep -vxF -f <(echo "${wt_branches}") || true)

  interactive_branch_delete "${old_branches}" "old"
}

function interactive_worktree_delete() {
  local worktrees=$1

  if [[ -z "${worktrees}" ]]; then
    echo "No stale worktrees discovered"
    return
  fi

  echo "Worktrees to delete:"
  for wt in ${worktrees}; do
    echo "${wt}"
  done

  read -p "Delete these worktrees [y/n/[p]ick]? : " -n 1 -r response
  echo

  if [[ ${response} =~ ^[Pp]$ ]]; then
    for wt in ${worktrees}; do
      echo "Worktree: ${wt}"
      echo
      read -p "Delete ${wt}? [y/n] : " -n 1 -r answer
      echo

      if [[ ${answer} =~ ^[Yy]$ ]]; then
        git worktree remove "${wt}"
      fi
    done

    return
  fi

  if [[ ! ${response} =~ ^[Yy]$ ]]; then
    return
  fi

  for wt in ${worktrees}; do
    git worktree remove "${wt}"
  done
}

function worktrees() {
  local main_worktree
  main_worktree=$(git worktree list | head -1 | awk '{print $1}')

  local stale_worktrees
  stale_worktrees=$(git worktree list | awk -v main="${main_worktree}" '$1 != main {print $1}')

  interactive_worktree_delete "${stale_worktrees}"
}

function main() {
  git fetch -p -q

  stale
  merged
  old
  worktrees
}

main
